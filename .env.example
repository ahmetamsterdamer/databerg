# databerganalytics — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ──────────────────────────────────────────────────────────────────────────
# Resend — https://resend.com
# Sign up (free tier: 100 emails/day), create an API key in the dashboard,
# paste it here. Required for the contact form to actually send.
# ──────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# The address to receive contact-form submissions. Defaults to the site
# contact email if unset. Override for testing.
CONTACT_TO_EMAIL=ahmetkarabasdtengineer@gmail.com

# The `from:` address on outgoing mail. `onboarding@resend.dev` works
# out of the box for any Resend account (good for dev). For production,
# verify a domain on Resend and use e.g. `contact@databerganalytics.com`.
CONTACT_FROM_EMAIL=onboarding@resend.dev

# ──────────────────────────────────────────────────────────────────────────
# Cloudflare Turnstile — https://developers.cloudflare.com/turnstile/
# Free. Create a site, copy both keys. Site key is public (shipped to
# browsers). Secret key is server-side only.
# Without Turnstile configured the form still works; the widget is
# skipped and the server does not perform captcha verification.
# ──────────────────────────────────────────────────────────────────────────
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Plausible Analytics — https://plausible.io (or self-hosted)
# Privacy-friendly, cookieless, GDPR-compliant. Set this to the domain
# you register in Plausible (the public hostname, no scheme, no path).
# Leave empty in dev. The tracker is only emitted when this is set.
# For a self-hosted instance, also set PUBLIC_PLAUSIBLE_SRC.
# ──────────────────────────────────────────────────────────────────────────
PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js
