---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import Link from '../../components/ui/Link.astro';
import Tag from '../../components/ui/Tag.astro';
import { getService, type Service } from '../../lib/services';

export async function getStaticPaths() {
  const entries: CollectionEntry<'work'>[] = await getCollection(
    'work',
    (entry: CollectionEntry<'work'>) => !entry.data.draft && entry.data.locale === 'en',
  );
  return entries.map((entry: CollectionEntry<'work'>) => ({
    params: { slug: entry.data.slug ?? entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

const allEntries: CollectionEntry<'work'>[] = await getCollection(
  'work',
  (e: CollectionEntry<'work'>) => !e.data.draft && e.data.locale === 'en',
);
const otherEntries = allEntries.filter((e: CollectionEntry<'work'>) => e.id !== entry.id).slice(0, 2);

const relatedServices: Service[] = (data.services ?? [])
  .map((slug: string) => getService(slug))
  .filter((s: Service | undefined): s is Service => Boolean(s));
---

<BaseLayout title={data.title} description={data.summary}>
  <article>

    <!-- Breadcrumb -->
    <section class="mx-auto max-w-7xl px-6 pt-24 md:pt-32">
      <Link href="/work">
        <span aria-hidden="true">←</span>
        <span>All work</span>
      </Link>
    </section>

    <!-- Header -->
    <section class="mx-auto max-w-7xl px-6 pt-10 pb-16">
      <div class="flex flex-wrap items-center gap-2">
        <Tag>{data.sector}</Tag>
        {data.location && <Tag>{data.location}</Tag>}
        {data.featured && <Tag variant="accent">Current engagement</Tag>}
      </div>
      <h1 class="mt-8 max-w-4xl font-display text-4xl leading-[1.1] tracking-tight md:text-6xl lg:text-7xl">
        {data.title}
      </h1>
      <p class="mt-8 max-w-3xl text-lg leading-relaxed text-ink-muted md:text-xl">
        {data.summary}
      </p>
    </section>

    <!-- Meta bar -->
    <section class="border-y border-line/60 bg-bg">
      <dl class="mx-auto grid max-w-7xl grid-cols-1 gap-px bg-line px-0 md:grid-cols-3">
        <div class="bg-bg px-6 py-5">
          <dt class="font-mono text-[10px] uppercase tracking-wider text-ink-muted">Duration</dt>
          <dd class="mt-2 font-display text-base text-ink">{data.duration}</dd>
        </div>
        <div class="bg-bg px-6 py-5">
          <dt class="font-mono text-[10px] uppercase tracking-wider text-ink-muted">Stack</dt>
          <dd class="mt-2 flex flex-wrap gap-1.5">
            {data.stack.map((s: string) => <Tag>{s}</Tag>)}
          </dd>
        </div>
        <div class="bg-bg px-6 py-5">
          <dt class="font-mono text-[10px] uppercase tracking-wider text-ink-muted">Services</dt>
          <dd class="mt-2 flex flex-wrap gap-1.5">
            {
              relatedServices.length > 0 ? (
                relatedServices.map((s) => <Tag>{s.category}</Tag>)
              ) : (
                <span class="text-sm text-ink-muted">&mdash;</span>
              )
            }
          </dd>
        </div>
      </dl>
    </section>

    <!-- Outcomes -->
    {
      data.outcomes && data.outcomes.length > 0 && (
        <section class="bg-bg">
          <div class="mx-auto max-w-7xl px-6 py-20 md:py-28">
            <p class="font-mono text-xs uppercase tracking-wider text-accent">Outcomes</p>
            <ul class="mt-8 grid grid-cols-1 gap-px border border-line bg-line md:grid-cols-3">
              {data.outcomes.map((o: { metric: string; note: string }) => (
                <li class="bg-bg p-6 md:p-8">
                  <p
                    class="font-display text-4xl leading-none tracking-tight text-accent md:text-5xl"
                    set:html={o.metric}
                  />
                  <p class="mt-4 text-sm leading-relaxed text-ink-muted">{o.note}</p>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )
    }

    <!-- Body -->
    <section class="border-t border-line/60 bg-bg">
      <div class="mx-auto max-w-7xl px-6 py-20 md:py-28">
        <div class="grid gap-8 md:grid-cols-12">
          <div class="md:col-span-4">
            <p class="font-mono text-xs uppercase tracking-wider text-accent">Narrative</p>
            <p class="mt-4 max-w-xs text-sm text-ink-muted">
              The problem, the approach, and what changed. In the client&rsquo;s voice where the work itself called for it.
            </p>
          </div>
          <div class="prose-body md:col-span-8">
            <Content />
          </div>
        </div>
      </div>
    </section>

    <!-- Related services -->
    {
      relatedServices.length > 0 && (
        <section class="border-t border-line/60 bg-bg">
          <div class="mx-auto max-w-7xl px-6 py-16">
            <p class="font-mono text-xs uppercase tracking-wider text-ink-muted">Related services</p>
            <ul class="mt-6 grid grid-cols-1 gap-px border border-line bg-line md:grid-cols-2">
              {relatedServices.map((s) => (
                <li class="bg-bg">
                  <a
                    href={`/services/${s.slug}`}
                    class="group/card flex h-full items-start justify-between gap-4 p-6 transition-colors hover:bg-surface focus-visible:outline focus-visible:-outline-offset-2 focus-visible:outline-2 focus-visible:outline-accent"
                  >
                    <div>
                      <Tag>{s.category}</Tag>
                      <p class="mt-3 font-display text-lg leading-tight tracking-tight">{s.title}</p>
                    </div>
                    <span
                      aria-hidden="true"
                      class="inline-block translate-y-1 text-ink-muted transition-all group-hover/card:translate-x-1 group-hover/card:text-accent"
                    >
                      →
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )
    }

    <!-- Closing CTA -->
    <section class="border-t border-line/60 bg-surface">
      <div class="mx-auto max-w-5xl px-6 py-24 text-center md:py-32">
        <p class="font-mono text-xs uppercase tracking-wider text-accent">Ready when you are</p>
        <h2 class="mt-6 font-display text-4xl leading-tight tracking-tight md:text-6xl">
          A 30-minute call. No slides.
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-ink-muted">
          Tell us what is expensive, slow, or confusing. We will tell you honestly whether we are the right fit.
        </p>
        <div class="mt-10 flex justify-center">
          <Button href="/contact" size="lg">Book a call</Button>
        </div>
      </div>
    </section>

    <!-- Other work -->
    {
      otherEntries.length > 0 && (
        <section class="border-t border-line/60 bg-bg">
          <div class="mx-auto max-w-7xl px-6 py-16">
            <p class="font-mono text-xs uppercase tracking-wider text-ink-muted">More work</p>
            <ul class="mt-8 grid grid-cols-1 gap-px border border-line bg-line md:grid-cols-2">
              {otherEntries.map((e) => (
                <li class="bg-bg">
                  <a
                    href={`/work/${e.id}`}
                    class="group/card flex h-full flex-col gap-4 p-6 transition-colors hover:bg-surface focus-visible:outline focus-visible:-outline-offset-2 focus-visible:outline-2 focus-visible:outline-accent md:p-8"
                  >
                    <div class="flex flex-wrap gap-2">
                      <Tag>{e.data.sector}</Tag>
                      {e.data.location && <Tag>{e.data.location}</Tag>}
                    </div>
                    <p class="font-display text-xl leading-tight tracking-tight transition-colors group-hover/card:text-accent md:text-2xl">
                      {e.data.title}
                    </p>
                    <span class="mt-auto flex items-baseline gap-1 font-mono text-xs uppercase tracking-wider text-ink-muted transition-colors group-hover/card:text-accent">
                      Read case
                      <span aria-hidden="true" class="inline-block translate-y-px transition-transform group-hover/card:translate-x-1">→</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .prose-body :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-ink);
  }
  .prose-body :global(h2:first-child) {
    margin-top: 0;
  }
  .prose-body :global(h3) {
    font-family: var(--font-display);
    font-size: 1.125rem;
    line-height: 1.3;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--color-ink);
  }
  .prose-body :global(p) {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-ink-muted);
    margin-top: 1rem;
  }
  .prose-body :global(p:first-child) {
    margin-top: 0;
  }
  .prose-body :global(p strong) {
    color: var(--color-ink);
    font-weight: 500;
  }
  .prose-body :global(ul) {
    margin-top: 1rem;
    padding-left: 1.25rem;
    list-style: none;
  }
  .prose-body :global(ul li) {
    position: relative;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-ink-muted);
    margin-top: 0.5rem;
  }
  .prose-body :global(ul li::before) {
    content: '';
    position: absolute;
    left: -1.25rem;
    top: 0.75em;
    width: 0.4rem;
    height: 1px;
    background-color: var(--color-accent);
  }
  .prose-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--color-accent);
    background-color: var(--color-surface);
    padding: 0.1em 0.35em;
  }
  .prose-body :global(a) {
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }
  .prose-body :global(a:hover) {
    color: var(--color-accent);
  }
</style>
