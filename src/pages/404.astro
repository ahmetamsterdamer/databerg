---
import BaseLayout from '../layouts/BaseLayout.astro';
import Link from '../components/ui/Link.astro';
---

<BaseLayout title="Not found" noIndex={true}>
  <section class="mx-auto max-w-3xl px-6 py-32 md:py-48">
    <p class="font-mono text-xs uppercase tracking-wider text-accent">404</p>
    <h1 class="mt-6 font-display text-4xl leading-tight tracking-tight md:text-6xl">
      That page isn&rsquo;t here.
    </h1>
    <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-muted">
      Likely a moved or mistyped link. Head back to the home page, or reach us directly.
    </p>
    <div class="mt-10 flex flex-wrap gap-6 text-sm">
      <Link href="/">Home</Link>
      <Link href="/contact">Contact</Link>
    </div>
  </section>
</BaseLayout>
