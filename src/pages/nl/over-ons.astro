---
// TODO(review-nl): Nederlandse vertaling van de About-pagina. "u"-vorm, B2B-toon.

import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import Link from '../../components/ui/Link.astro';

interface Engagement {
  years: string;
  sector: string;
  summary: string;
  caseSlug?: string;
}

const engagements: Engagement[] = [
  {
    years: '2023 — nu',
    sector: 'Nederlandse zorgverzekeraar',
    summary:
      'Analytische rapportage op Azure Synapse. T-SQL-tuning, pipeline-automatisering, SLA-dashboards. Lopend traject.',
    caseSlug: 'health-insurer-analytics',
  },
  {
    years: '2022 — 2023',
    sector: 'Wereldwijde IT-consultancypartner',
    summary:
      'Legacy SSIS ETL afgebouwd. Migratie naar ADF + Databricks, met CI/CD-beheerde SQL-deployments.',
    caseSlug: 'consulting-ssis-migration',
  },
  {
    years: '2019 — 2022',
    sector: 'Retailbank in EMEA',
    summary:
      'Queryperformance op fact-tabellen van miljard rijen, herbruikbare T-SQL-bibliotheken, mentorschap voor junior engineers over indexering en partitionering.',
    caseSlug: 'banking-query-performance',
  },
];

interface Principle {
  number: string;
  title: string;
  body: string;
}

const principles: Principle[] = [
  {
    number: '01',
    title: 'Scope is geschreven, of bestaat niet.',
    body: 'Elk traject begint met een kort geschreven plan dat de klant in één alinea kan samenvatten. Als we het niet eens worden over die alinea, begint het traject niet.',
  },
  {
    number: '02',
    title: 'Geen retainer, geen lock-in.',
    body: 'Elk traject heeft een duidelijk begin, een duidelijk einde en een geschreven overdracht. U bent eigenaar van de output &mdash; de code, de documentatie, de onderbouwing. Wij vertrekken. Het werk blijft.',
  },
  {
    number: '03',
    title: 'Het team houdt de kennis.',
    body: 'Mentorschap is onderdeel van het traject, geen optionele toevoeging. De praktijken die wij introduceren &mdash; query-tuning, indexeringsstrategie, runbook-discipline &mdash; zijn bedoeld om het contract te overleven.',
  },
  {
    number: '04',
    title: 'Eerlijke cijfers, eerlijke scope.',
    body: 'Als wij niet de juiste match zijn, zeggen we dat in het gesprek. Als een traject dreigt vast te lopen onderweg, benoemen we dat in de week dat we het zien. De relatie duurt langer dan het traject.',
  },
  {
    number: '05',
    title: 'Documentatie is het werk.',
    body: 'Code zonder runbook is een morgenprobleem. Elk traject wordt opgeleverd mét de pagina die het uitlegt &mdash; genoeg dat een nieuwe teamgenoot het zonder meeting kan oppakken.',
  },
];

const education = [
  {
    degree: 'B.Sc. Computer Engineering',
    institution: 'Vrije Universiteit Amsterdam',
  },
  {
    degree: 'B.Sc. Operations Research',
    institution: 'Middle East Technical University',
  },
];

const certifications = [
  { name: 'Microsoft Certified: Azure Data Engineer Associate (DP-203)', year: '2023' },
  { name: 'Microsoft Azure Fundamentals (AZ-900)', year: '2022' },
  { name: 'Microsoft Fabric (AZ-700)', year: '2025' },
];
---

<BaseLayout
  title="Over ons"
  description="databerganalytics is een praktijk van één persoon. Ahmet Karabaş — Azure Data Engineer, Amsterdam. Vier jaar SQL-tuning, pipelinewerk en het rustige vakmanschap van data-teams sneller maken."
>
  <article>

    <section class="mx-auto max-w-7xl px-6 pt-24 pb-16 md:pt-32">
      <p class="font-mono text-xs uppercase tracking-wider text-accent">Over ons</p>
      <h1 class="mt-6 max-w-5xl font-display text-5xl leading-[1.05] tracking-tight md:text-7xl lg:text-8xl">
        databerganalytics is een praktijk van één. Dat is met opzet.
      </h1>
      <p class="mt-8 max-w-2xl text-lg leading-relaxed text-ink-muted md:text-xl">
        Alles wat u op deze site leest, spreekt u in het gesprek. Geen accountmanager, geen overdracht naar een junior, geen &ldquo;laat mij mijn collega erbij halen voor het technische gedeelte.&rdquo;
      </p>
    </section>

    <section class="border-t border-line/60 bg-bg">
      <div class="mx-auto grid max-w-7xl gap-12 px-6 py-20 md:grid-cols-12 md:py-28">
        <div class="md:col-span-4">
          <p class="font-mono text-xs uppercase tracking-wider text-accent">01 &middot; Wie</p>
          <div
            aria-hidden="true"
            class="mt-6 aspect-[3/4] max-w-xs border border-line bg-surface"
          >
            <div class="flex h-full items-center justify-center">
              <span class="font-mono text-[10px] uppercase tracking-wider text-ink-muted">
                foto &middot; volgt
              </span>
            </div>
          </div>
          <p class="mt-6 font-display text-2xl leading-tight tracking-tight">Ahmet Karaba&scedil;</p>
          <p class="mt-1 text-sm text-ink-muted">Azure Data Engineer &middot; Amsterdam</p>
        </div>

        <div class="space-y-6 md:col-span-8">
          <p class="text-lg leading-relaxed text-ink md:text-xl">
            Vier jaar aan drie trajecten die allemaal rijmden: een data warehouse was traag, een pipeline was broos, een team besteedde zijn week aan handwerk.
          </p>
          <p class="text-base leading-relaxed text-ink-muted md:text-lg">
            In alle drie was de oplossing minder glamoureus dan een pitchdeck zou suggereren &mdash; meer SQL-tuning, minder herarchitectuur. Indexeringsbeslissingen die jaren waren uitgesteld. Stored procedures die broze scripts vervingen. Herbruikbare bibliotheken die vier kopieën van dezelfde logica terugbrachten naar één. Het werk werd gedaan, de cijfers daalden, en het team hield de werkwijze vast nadat wij vertrokken waren.
          </p>
          <p class="text-base leading-relaxed text-ink-muted md:text-lg">
            De praktijk is rond die observatie opgebouwd. De meeste business-en-tech-optimalisatieproblemen hebben geen nieuw platform of nieuwe vendor nodig. Ze hebben iemand nodig die bereid is lang genoeg bij het bestaande systeem te zitten om te zien wat er daadwerkelijk wrijving geeft &mdash; en die de oplossing opschrijft zodat de volgende in het team het zo kan houden.
          </p>
          <p class="text-base leading-relaxed text-ink-muted md:text-lg">
            Vóór software: Operations Research aan METU en Computer Engineering aan de VU Amsterdam. Vrijwilliger bij het Leger des Heils in Amsterdam &mdash; data-gerelateerd werk, hetzelfde principe: verwijder de bottleneck, houd het doel in zicht.
          </p>
        </div>
      </div>
    </section>

    <section class="border-t border-line/60 bg-bg">
      <div class="mx-auto grid max-w-7xl gap-8 px-6 py-20 md:grid-cols-12 md:py-28">
        <div class="md:col-span-4">
          <p class="font-mono text-xs uppercase tracking-wider text-accent">02 &middot; Waar</p>
          <p class="mt-4 max-w-xs text-sm text-ink-muted">
            Drie trajecten, geanonimiseerd op verzoek van de klant. Het werk zelf staat in <Link href="/nl/cases">Cases</Link>.
          </p>
        </div>
        <ol class="md:col-span-8">
          {
            engagements.map((eng) => (
              <li class="border-t border-line/60 py-8 first:border-t-0 first:pt-0">
                <div class="grid gap-4 md:grid-cols-12 md:items-baseline md:gap-8">
                  <div class="md:col-span-3">
                    <p class="font-mono text-xs uppercase tracking-wider text-ink-muted">
                      {eng.years}
                    </p>
                  </div>
                  <div class="md:col-span-9">
                    <p class="font-display text-xl leading-tight tracking-tight text-ink md:text-2xl">
                      {eng.sector}
                    </p>
                    <p class="mt-3 text-base leading-relaxed text-ink-muted">{eng.summary}</p>
                    {eng.caseSlug && (
                      <p class="mt-4">
                        <Link href={`/nl/cases/${eng.caseSlug}`} variant="arrow" class="text-sm">
                          Lees case
                        </Link>
                      </p>
                    )}
                  </div>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="border-t border-line/60 bg-surface">
      <div class="mx-auto max-w-7xl px-6 py-20 md:py-28">
        <div class="grid gap-8 md:grid-cols-12">
          <div class="md:col-span-4">
            <p class="font-mono text-xs uppercase tracking-wider text-accent">03 &middot; Hoe</p>
            <h2 class="mt-6 font-display text-3xl leading-tight tracking-tight md:text-4xl">
              Vijf principes. Niet onderhandelbaar.
            </h2>
            <p class="mt-6 max-w-xs text-sm leading-relaxed text-ink-muted">
              Hier is het traject op gebouwd. Als één ervan ongemakkelijk voelt, zijn wij waarschijnlijk niet de juiste match &mdash; en dat is prima om in het gesprek te ontdekken.
            </p>
          </div>
          <ol class="divide-y divide-line/60 border-y border-line/60 md:col-span-8">
            {
              principles.map((p) => (
                <li class="grid gap-4 py-8 md:grid-cols-12 md:items-baseline md:gap-8">
                  <span class="font-mono text-xs uppercase tracking-wider text-accent md:col-span-2">
                    {p.number}
                  </span>
                  <div class="md:col-span-10">
                    <h3 class="font-display text-xl leading-tight tracking-tight text-ink md:text-2xl">
                      {p.title}
                    </h3>
                    <p class="mt-3 text-base leading-relaxed text-ink-muted" set:html={p.body} />
                  </div>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </section>

    <section class="border-t border-line/60 bg-bg">
      <div class="mx-auto max-w-7xl px-6 py-20 md:py-28">
        <div class="grid gap-8 md:grid-cols-12">
          <div class="md:col-span-4">
            <p class="font-mono text-xs uppercase tracking-wider text-accent">04 &middot; Opleiding &amp; certificering</p>
          </div>
          <div class="grid gap-px border border-line bg-line md:col-span-8 md:grid-cols-2">
            <div class="bg-bg p-6 md:p-8">
              <p class="font-mono text-[10px] uppercase tracking-wider text-ink-muted">Opleiding</p>
              <ul class="mt-6 space-y-6">
                {
                  education.map((e) => (
                    <li>
                      <p class="font-display text-base text-ink md:text-lg">{e.degree}</p>
                      <p class="mt-1 text-sm text-ink-muted">{e.institution}</p>
                    </li>
                  ))
                }
              </ul>
            </div>
            <div class="bg-bg p-6 md:p-8">
              <p class="font-mono text-[10px] uppercase tracking-wider text-ink-muted">Certificeringen</p>
              <ul class="mt-6 space-y-6">
                {
                  certifications.map((c) => (
                    <li>
                      <p class="font-display text-base text-ink md:text-lg">{c.name}</p>
                      <p class="mt-1 font-mono text-xs uppercase tracking-wider text-ink-muted">{c.year}</p>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-line/60 bg-bg">
      <div class="mx-auto max-w-7xl px-6 py-12">
        <div class="grid gap-4 md:grid-cols-12 md:items-baseline">
          <div class="md:col-span-4">
            <p class="font-mono text-xs uppercase tracking-wider text-accent">05 &middot; Buiten het werk</p>
          </div>
          <div class="md:col-span-8">
            <p class="text-base leading-relaxed text-ink-muted md:text-lg">
              Vrijwilligerscoördinator bij het Leger des Heils in Amsterdam. Vrijwilligersteams en logistiek; gestructureerde rapportage geïntroduceerd bij een ploeg die die nog niet had. Hetzelfde principe als in het dagwerk: verwijder de bottleneck, houd het doel in zicht.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-line/60 bg-surface">
      <div class="mx-auto max-w-5xl px-6 py-24 text-center md:py-32">
        <p class="font-mono text-xs uppercase tracking-wider text-accent">Wij staan klaar</p>
        <h2 class="mt-6 font-display text-4xl leading-tight tracking-tight md:text-6xl">
          Een gesprek van 30 minuten. Geen slides.
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-ink-muted">
          Vertel ons wat duur, traag of onduidelijk is. Wij zeggen eerlijk of we de juiste match zijn.
        </p>
        <div class="mt-10 flex justify-center">
          <Button href="/nl/contact" size="lg">Plan een gesprek</Button>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
