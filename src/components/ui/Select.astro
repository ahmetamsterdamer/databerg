---
import type { HTMLAttributes } from 'astro/types';

interface Props extends Omit<HTMLAttributes<'select'>, 'class'> {
  id: string;
  label: string;
  hint?: string;
  class?: string;
  wrapperClass?: string;
}

const {
  id,
  name = id,
  label,
  required = false,
  hint,
  class: className = '',
  wrapperClass = '',
  ...rest
} = Astro.props;

const hintId = hint ? `${id}-hint` : undefined;
---

<div class={`flex flex-col gap-2 ${wrapperClass}`}>
  <label for={id} class="font-mono text-xs uppercase tracking-wider text-ink-muted">
    {label}
    {required && <span aria-hidden="true" class="text-accent"> *</span>}
  </label>
  <div class="relative">
    <select
      id={id}
      name={name}
      required={required}
      aria-describedby={hintId}
      class={[
        'h-12 w-full appearance-none border border-line bg-surface px-4 pr-10 text-sm text-ink',
        'focus-visible:border-accent focus-visible:outline-none',
        'disabled:cursor-not-allowed disabled:opacity-50',
        'transition-colors',
        className,
      ]
        .filter(Boolean)
        .join(' ')}
      {...rest}
    >
      <slot />
    </select>
    <svg
      aria-hidden="true"
      class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-ink-muted"
      width="12"
      height="12"
      viewBox="0 0 12 12"
      fill="none"
    >
      <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
    </svg>
  </div>
  {hint && <p id={hintId} class="text-xs text-ink-muted">{hint}</p>}
</div>
