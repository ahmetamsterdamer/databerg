---
import Button from '../ui/Button.astro';
import { alternateLocaleUrl, getLocaleFromPath, NAV_ROUTES, t } from '../../lib/i18n';

const pathname = Astro.url.pathname;
const locale = getLocaleFromPath(pathname);
const altHref = alternateLocaleUrl(pathname);
const homeHref = locale === 'nl' ? '/nl/' : '/';
const contactHref = locale === 'en' ? '/contact' : '/nl/contact';
const routes = NAV_ROUTES[locale];
---

<header
  class="sticky top-0 z-40 w-full border-b border-line/60 bg-bg/85 backdrop-blur-md"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
    <a
      href={homeHref}
      class="font-display text-lg leading-none tracking-tight text-ink transition-colors hover:text-accent"
      aria-label="databerganalytics, home"
    >
      databerganalytics
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-8 md:flex">
      {
        routes.map((route) => (
          <a
            href={route.href}
            class="text-sm text-ink-muted transition-colors hover:text-ink"
          >
            {t(locale, route.label)}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-4">
      <div class="hidden items-center gap-2 font-mono text-xs uppercase tracking-wider md:flex" aria-label="Language">
        {
          locale === 'en' ? (
            <span class="text-ink" aria-current="true">EN</span>
          ) : (
            <a href={altHref} class="text-ink-muted transition-colors hover:text-ink">EN</a>
          )
        }
        <span class="text-line" aria-hidden="true">/</span>
        {
          locale === 'nl' ? (
            <span class="text-ink" aria-current="true">NL</span>
          ) : (
            <a href={altHref} class="text-ink-muted transition-colors hover:text-ink">NL</a>
          )
        }
      </div>

      <Button href={contactHref} size="md">
        {t(locale, 'ctaBookCall')}
      </Button>
    </div>
  </div>
</header>
