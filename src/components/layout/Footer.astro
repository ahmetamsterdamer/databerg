---
import { alternateLocaleUrl, getLocaleFromPath, NAV_ROUTES, t } from '../../lib/i18n';

const pathname = Astro.url.pathname;
const locale = getLocaleFromPath(pathname);
const altHref = alternateLocaleUrl(pathname);
const routes = NAV_ROUTES[locale];

// TODO(copy): confirm NL legal details (KvK, BTW) before launch.
const contactEmail = 'ahmetkarabasdtengineer@gmail.com';
const year = new Date().getFullYear();
---

<footer class="mt-32 border-t border-line/60 bg-bg">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
      <div class="md:col-span-5">
        <p class="font-display text-xl leading-tight tracking-tight text-ink">databerganalytics</p>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-ink-muted">{t(locale, 'footerTagline')}</p>
      </div>

      <div class="md:col-span-3">
        <p class="font-mono text-xs uppercase tracking-wider text-ink-muted">{t(locale, 'footerContact')}</p>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a
              href={`mailto:${contactEmail}`}
              class="text-ink transition-colors hover:text-accent"
            >{contactEmail}</a>
          </li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <p class="font-mono text-xs uppercase tracking-wider text-ink-muted">{t(locale, 'footerNav')}</p>
        <ul class="mt-4 space-y-2 text-sm">
          {
            routes.map((route) => (
              <li>
                <a
                  href={route.href}
                  class="text-ink-muted transition-colors hover:text-ink"
                >{t(locale, route.label)}</a>
              </li>
            ))
          }
          <li>
            <a
              href={locale === 'nl' ? '/nl/insights' : '/insights'}
              class="text-ink-muted transition-colors hover:text-ink"
            >{locale === 'nl' ? 'Inzichten' : 'Insights'}</a>
          </li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <p class="font-mono text-xs uppercase tracking-wider text-ink-muted">Language</p>
        <ul class="mt-4 space-y-2 font-mono text-xs uppercase tracking-wider">
          <li>
            {
              locale === 'en' ? (
                <span class="text-ink" aria-current="true">EN</span>
              ) : (
                <a href={altHref} class="text-ink-muted transition-colors hover:text-ink">EN</a>
              )
            }
          </li>
          <li>
            {
              locale === 'nl' ? (
                <span class="text-ink" aria-current="true">NL</span>
              ) : (
                <a href={altHref} class="text-ink-muted transition-colors hover:text-ink">NL</a>
              )
            }
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-start justify-between gap-4 border-t border-line/60 pt-6 text-xs text-ink-muted md:flex-row md:items-center">
      <p>&copy; {year} databerganalytics. {t(locale, 'footerCopyright')}</p>
      <p class="font-mono">v0.0.1 &middot; in development</p>
    </div>
  </div>
</footer>
