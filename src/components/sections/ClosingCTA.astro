---
import Button from '../ui/Button.astro';
import { getLocaleFromPath, t } from '../../lib/i18n';

const locale = getLocaleFromPath(Astro.url.pathname);
const contactHref = locale === 'nl' ? '/nl/contact' : '/contact';
---

<section class="border-t border-line/60 bg-surface">
  <div class="mx-auto max-w-4xl px-6 py-24 text-center md:py-32">
    <p class="font-mono text-xs uppercase tracking-wider text-accent">{t(locale, 'closingEyebrow')}</p>
    <h2 class="mt-6 font-display text-4xl leading-tight tracking-tight md:text-6xl">
      {t(locale, 'closingTitle')}
    </h2>
    <p class="mt-6 text-lg leading-relaxed text-ink-muted">
      {t(locale, 'closingBody')}
    </p>
    <div class="mt-10 flex justify-center">
      <Button href={contactHref} size="lg">{t(locale, 'ctaBookCall')}</Button>
    </div>
  </div>
</section>
